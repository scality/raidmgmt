{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "abandonments:recommended"
  ],

  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "groupName": "Go module dependencies",
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "rangeStrategy": "bump"
    }
  ],

  "go": {
    "privateRegistries": [
      "github.com/scality"
    ]
  }
}
